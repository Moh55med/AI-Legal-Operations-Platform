# FastAPI Configuration
DEBUG=False
APP_NAME="AI Legal Operations Platform"

# Database Configuration
# Format: postgresql://username:password@hostname:port/database_name
# Example: postgresql://legal_user:secure_password@localhost:5432/legal_platform
DATABASE_URL=postgresql://user:password@localhost:5432/legal_platform

# Database Connection Pool Settings
DATABASE_ECHO=False
DATABASE_POOL_SIZE=20
DATABASE_POOL_RECYCLE=3600
DATABASE_POOL_PRE_PING=True
DATABASE_MAX_OVERFLOW=10

# AI/Claude API Configuration
# Get your API key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
CLAUDE_MODEL=claude-3-5-sonnet-20241022
